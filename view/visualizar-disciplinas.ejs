<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <link rel="stylesheet" href="/css/style.css">
    <title>Visualizar Disciplinas</title>
</head>
<body>
    <h1>Lista de Disciplinas</h1>

    <div class="container">
        <% disciplinas.forEach(disciplina => { %>
            <div class="card">
                <h3>Nome: <%= disciplina.nome %></h3>
                <p>Carga Horária: <%= disciplina.cargaHoraria %></p>
                <p>Professor: <%= disciplina.professor %></p>
            </div>
        <% }); %>
    </div>
</body>
</html>